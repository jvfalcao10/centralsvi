{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/interno/:file(.*\\.html)", "destination": "/interno/:file" },
    { "source": "/r/trafego/:slug", "destination": "/index.html" },
    { "source": "/r/(.*)", "destination": "/api/r?slug=$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
